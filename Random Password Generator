import random as r
import string as s
length = int(input('enter the preferred length of the password: '))
uc = input('do you want upper case letters(y/n):').lower()
lc = input('do you want lower case letters(y/n): ').lower()
sc = input('do you want special case letters(y/n): ').lower()
no = input('do you want digits (y/n): ').lower()

upper = s.ascii_uppercase
lower = s.ascii_lowercase
nos = s.digits
special = s.punctuation

char = ''
if uc == 'y':
    char += upper
if lc == 'y':
    char += lower
if sc == 'y':
    char += special
if no == 'y':
    char += nos

if char:
        password = ''.join(r.choice(char) for _ in range(length))
        print(f'password is {password}')
else:
    print("select some type of characters to add to pass")
